# Скопируйте в .env рядом с docker-compose.yml и подставьте значения.

# Публичный URL CRM (без слэша в конце). Обязательно для входа и OAuth.
APP_PUBLIC_URL=https://crm.example.com

POSTGRES_USER=nextcrm
POSTGRES_PASSWORD=сгенерируйте_надёжный_пароль
POSTGRES_DB=nextcrm

# Почта администратора — первый пользователь создаётся сидом (ACTIVE, admin).
ADMIN_EMAIL=you@yourdomain.com

# Resend — нужен для кода входа по email (OTP). https://resend.com
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM="GERS CRM <noreply@yourdomain.com>"

# Секрет для заявок с сайта (Bearer в заголовке Authorization).
NEXTCRM_TOKEN=сгенерируйте_случайную_строку_32plus

# Если форма на gers.agency шлёт fetch из браузера напрямую в CRM — укажите origin через запятую.
# GERS_WEBHOOK_ALLOWED_ORIGINS=https://gers.agency

# Google OAuth (опционально)
GOOGLE_ID=
GOOGLE_SECRET=

# Опционально: ключи ИИ не обязательны в slim-режиме
OPENAI_API_KEY=
FIRECRAWL_API_KEY=
E2B_API_KEY=
