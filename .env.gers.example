# =============================================================================
# GERS / NextCRM — пример переменных окружения
# =============================================================================
# Docker: скопируйте в .env рядом с docker-compose.yml.
# Vercel: Project → Settings → Environment Variables — те же имена (Production).
# Секреты в git не коммитить; после утечки — перевыпустить.
# =============================================================================

# --- Публичный URL CRM (без слэша в конце) ---
APP_PUBLIC_URL=https://crm.example.com

# --- Postgres для Prisma (НЕ anon key Supabase; нужна строка postgresql://…) ---
# Локально (docker-compose подставляет из POSTGRES_*):
# DATABASE_URL=postgresql://nextcrm:ПАРОЛЬ@postgres:5432/nextcrm
# Supabase pooler (пример): порт 6543 + в конец URI:
#   ?pgbouncer=true&sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

POSTGRES_USER=nextcrm
POSTGRES_PASSWORD=сгенерируйте_надёжный_пароль
POSTGRES_DB=nextcrm

# --- Better Auth (обязательно на Vercel; без этого — «default secret» и 500) ---
# Сгенерируйте ОДИН раз и сохраните (≥32 символа, не текст из примера ниже):
#   openssl rand -base64 48
#   или PowerShell: [Convert]::ToBase64String((1..48|%{Get-Random -Max 256}))
BETTER_AUTH_SECRET=ЗАМЕНИТЕ_НА_РЕЗУЛЬТАТ_openssl_rand_base64_48
# Точный URL открытия CRM в браузере (без / в конце). На Vercel: https://ваш-проект.vercel.app
BETTER_AUTH_URL=https://crm.example.com
NEXT_PUBLIC_APP_URL=https://crm.example.com
# Опционально: свой домен не покрывается *.vercel.app — перечислить host через запятую
# BETTER_AUTH_ALLOWED_HOSTS=crm.example.com,www.crm.example.com

# --- UI форка ---
NEXT_PUBLIC_APP_NAME=GERS CRM
NEXT_PUBLIC_GERS_SLIM_UI=1

# --- Почта (Resend) — уведомления админам о регистрациях и т.п. ---
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM="GERS CRM <noreply@yourdomain.com>"

# --- Сид: первый админ + тестовый логин (см. prisma/seeds/seed.ts) ---
ADMIN_EMAIL=you@yourdomain.com
# TEST_USER_USERNAME=testuser
# TEST_USER_PASSWORD=YourStrongPasswordHere

# --- Вебхук заявок с сайта (Bearer Authorization) ---
NEXTCRM_TOKEN=сгенерируйте_случайную_строку_32plus

# Если форма шлёт fetch из браузера на другой домен:
# GERS_WEBHOOK_ALLOWED_ORIGINS=https://gers.agency

# --- Шифрование вложений/писем в приложении (64 hex = openssl rand -hex 32) ---
# EMAIL_ENCRYPTION_KEY=

# --- MinIO / S3 (если нужны файлы; на Vercel обычно свой S3/R2) ---
# NEXT_PUBLIC_MINIO_ENDPOINT=
# MINIO_ENDPOINT=
# MINIO_PORT=9000
# MINIO_BUCKET=
# MINIO_USE_SSL=false
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=

# --- Inngest (фоновые задачи; можно заглушки, если не используете) ---
# INNGEST_ID=
# INNGEST_APP_NAME=
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# --- Опционально: ИИ и прочее ---
OPENAI_API_KEY=
FIRECRAWL_API_KEY=
E2B_API_KEY=
